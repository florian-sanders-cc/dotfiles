// Zed keymap - Aligned with Neovim configuration
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  // =====================================================
  // GLOBAL APP-LEVEL (no context)
  // Works in editor, terminal, dock, panels — everywhere.
  // These are Ctrl-combos, safe to bind globally since
  // they are never typed as literal text.
  // =====================================================
  {
    "bindings": {
      "ctrl-+":       ["zed::IncreaseBufferFontSize", { "persist": true }],
      "ctrl--":       ["zed::DecreaseBufferFontSize", { "persist": true }],
      "ctrl-s":       "workspace::Save",
      "ctrl-shift-p": "command_palette::Toggle",
      "ctrl-,":       "zed::OpenSettings",
      "ctrl-k ctrl-s": "zed::OpenKeymap",
      "ctrl-p":       "file_finder::Toggle",
      "ctrl-y":       "workspace::CopyPath",
      "ctrl-shift-y": "workspace::CopyRelativePath"
    }
  },

  // =====================================================
  // GLOBAL MODAL / PICKER ESSENTIALS (no context)
  // Restores escape/enter/arrow navigation stripped by
  // base_keymap: "None". Applies to command palette,
  // file finder, any picker or modal overlay.
  // =====================================================
  {
    "bindings": {
      "escape": "menu::Cancel",
      "enter":  "menu::Confirm",
      "up":     "menu::SelectPrevious",
      "down":   "menu::SelectNext",
      "shift-tab": "menu::SelectPrevious"
    }
  },

  // =====================================================
  // EDITOR INPUT FIELDS (broad Editor context)
  // Covers single-line inputs in pickers, search bars,
  // etc. which are Editor components but NOT in vim_mode.
  // In vim mode buffers, the vim layer takes precedence
  // for escape (exit insert → normal), so no conflict.
  // =====================================================
  {
    "context": "Editor",
    "bindings": {
      "backspace": "editor::Backspace",
      "escape":    "editor::Cancel"
    }
  },

  // =====================================================
  // BUFFER SEARCH BAR
  // =====================================================
  {
    "context": "BufferSearchBar",
    "bindings": {
      "escape":      "buffer_search::Dismiss",
      "enter":       "search::SelectNextMatch",
      "shift-enter": "search::SelectPreviousMatch"
    }
  },

  // =====================================================
  // GLOBAL CTRL-W WINDOW PREFIX (no context)
  // Vim-style windowing available everywhere — editor,
  // terminal, dock, panels. No standalone ctrl-w binding
  // so ctrl-w is a pure prefix with no 1s timeout race.
  //
  // NOTE: ctrl-w c is intentionally remapped to
  // CloseAllItems (diverges from vim's "close window").
  // Use ctrl-w q for single close (vim parity for :q).
  // =====================================================
  {
    "bindings": {
      // Navigation (mirrors <C-w>h/j/k/l)
      "ctrl-w h":      "workspace::ActivatePaneLeft",
      "ctrl-w j":      "workspace::ActivatePaneDown",
      "ctrl-w k":      "workspace::ActivatePaneUp",
      "ctrl-w l":      "workspace::ActivatePaneRight",
      "ctrl-w w":      "workspace::ActivateNextPane",
      "ctrl-w ctrl-w": "workspace::ActivateNextPane",

      // Resize with arrow keys (no timeout race — not a prefix)
      "ctrl-w left":  "vim::ResizePaneLeft",
      "ctrl-w right": "vim::ResizePaneRight",
      "ctrl-w up":    "vim::ResizePaneUp",
      "ctrl-w down":  "vim::ResizePaneDown",

      // Resize with symbolic keys (vim parity)
      "ctrl-w >": "vim::ResizePaneRight",
      "ctrl-w <": "vim::ResizePaneLeft",
      "ctrl-w +": "vim::ResizePaneUp",
      "ctrl-w -": "vim::ResizePaneDown",

      // Equalize / zoom
      "ctrl-w =":      "vim::ResetPaneSizes",
      "ctrl-w ctrl-=": "vim::ResetPaneSizes",
      "ctrl-w z":      "workspace::ToggleZoom",
      "ctrl-w ctrl-z": "workspace::ToggleZoom",

      // Splits (mirrors <C-w>s / <C-w>v)
      "ctrl-w s":      "pane::SplitDown",
      "ctrl-w ctrl-s": "pane::SplitDown",
      "ctrl-w v":      "pane::SplitRight",
      "ctrl-w ctrl-v": "pane::SplitRight",

      // Close active item (mirrors <C-w>q / :q)
      "ctrl-w q":      "pane::CloseActiveItem",
      "ctrl-w ctrl-q": "pane::CloseActiveItem",

      // Close ALL items (repurposed; diverges from vim's <C-w>c)
      "ctrl-w c":      "pane::CloseAllItems",
      "ctrl-w ctrl-c": "pane::CloseAllItems",

      // Close others (mirrors <C-w>o)
      "ctrl-w o":      "pane::CloseOtherItems",
      "ctrl-w ctrl-o": "pane::CloseOtherItems",

      // Swap with adjacent pane (mirrors <C-w>x)
      "ctrl-w x": "workspace::SwapPaneAdjacent",

      // Move pane (mirrors <C-w>H/J/K/L)
      "ctrl-w H": "workspace::SwapPaneLeft",
      "ctrl-w J": "workspace::SwapPaneDown",
      "ctrl-w K": "workspace::SwapPaneUp",
      "ctrl-w L": "workspace::SwapPaneRight"
    }
  },

  // =====================================================
  // INSERT-MODE COMPLETION & PREDICTION
  // Explicitly restores tab/enter/shift-tab behavior
  // removed by base_keymap: "None".
  // Precedence (higher context specificity wins):
  //   edit_prediction && !showing_completions → tab accepts prediction
  //   showing_completions → tab composes, enter confirms
  //   otherwise → tab indents (editor::Tab)
  // =====================================================
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "tab":       "editor::Tab",      // literal indent (fallback)
      "shift-tab": "editor::Backtab",
      "ctrl-e":    "editor::Cancel"    // cancel completion / prediction
    }
  },
  {
    // Accepts edit prediction when one is visible (any prediction mode,
    // including "subtle"). Overrides the generic tab → editor::Tab above.
    "context": "Editor && vim_mode == insert && edit_prediction && !showing_completions",
    "bindings": {
      "tab": "editor::AcceptEditPrediction"
    }
  },
  {
    // When completion menu is open: compose completion on tab, confirm on enter.
    "context": "Editor && vim_mode == insert && showing_completions",
    "bindings": {
      "tab":   "editor::ComposeCompletion",
      "enter": "editor::ConfirmCompletion"
    }
  },
  {
    // Snippet tabstop navigation (stripped by base_keymap: None — restore).
    "context": "Editor && in_snippet && has_next_tabstop && !showing_completions",
    "bindings": {
      "tab": "editor::NextSnippetTabstop"
    }
  },
  {
    "context": "Editor && in_snippet && has_previous_tabstop && !showing_completions",
    "bindings": {
      "shift-tab": "editor::PreviousSnippetTabstop"
    }
  },

  // =====================================================
  // UNBIND VSCode BASE ctrl-w CONFLICTS
  // VSCode base binds standalone ctrl-w to close pane/dock in
  // these contexts. We nullify them so ctrl-w functions as a
  // pure prefix (no 1s timeout race) for the window bindings
  // in the global ctrl-w section above.
  // =====================================================
  {
    "context": "Pane",
    "unbind": {
      "ctrl-w": "pane::CloseActiveItem"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-w": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "SettingsWindow",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow"
    }
  },
  {
    "context": "RulesLibrary",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow"
    }
  },

  // =====================================================
  // OVERRIDE VSCode ctrl-y IN EDITOR
  // VSCode base binds ctrl-y → editor::Redo (Editor ctx),
  // which takes precedence over our global CopyPath binding.
  // In vim buffers, vim.json handles ctrl-y as LineUp.
  // This ensures CopyPath works in non-vim Editor contexts.
  // =====================================================
  {
    "context": "Editor && !VimControl",
    "bindings": {
      "ctrl-y": "workspace::CopyPath"
    }
  },

  // =====================================================
  // NORMAL & VISUAL MODE BINDINGS
  // =====================================================
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      // Window splits — space-w prefix (mirrors Neovim <leader>w)
      "space w s": "pane::SplitDown",       // horizontal split (like <C-w>s)
      "space w v": "pane::SplitRight",      // vertical split (like <C-w>v)
      "space w _": "pane::SplitRight",      // alias kept for muscle memory
      "space w -": "pane::SplitDown",       // alias kept for muscle memory
      "space w q": "pane::CloseActiveItem", // close window (like <C-w>q)
      "space w d": "pane::CloseActiveItem", // alias
      "space w o": "pane::CloseOtherItems", // close others (like <C-w>o)
      "space w x": "workspace::SwapPaneAdjacent", // swap (like <C-w>x)
      "space w =": "vim::ResetPaneSizes",   // equalize (like <C-w>=)
      "space w r": "vim::ResetPaneSizes",   // mirrors Neovim MiniMisc.resize_window
      "space w z": "workspace::ToggleZoom", // zoom toggle (mirrors Neovim <leader>wz)
      "space w h": "workspace::ActivatePaneLeft",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      "space w l": "workspace::ActivatePaneRight",

      // Old split aliases at top-level (keep for existing muscle memory)
      "space _": "pane::SplitRight",
      "space -": "pane::SplitDown",

      // File explorer (matches Neovim <leader>e → Yazi)
      "space e": [
        "task::Spawn",
        { "task_name": "Yazi File Manager", "reveal_target": "center" }
      ],

      "space g D": [
        "task::Spawn",
        { "task_name": "Neogit", "reveal_target": "center" }
      ],

      // File finding (matches Neovim)
      "space space": "file_finder::Toggle",           // <leader><space>
      "space f f": "file_finder::Toggle",             // <leader>ff
      "space f r": "projects::OpenRecent",            // <leader>fr
      "space f g": "file_finder::Toggle",             // <leader>fg (approximate)
      "space ,": "buffer_search::Deploy",             // <leader>, for buffers

      // Search operations
      "space /": "buffer_search::Deploy",             // <leader>/
      "space s g": "project_panel::NewSearchInDirectory", // <leader>sg

      // Git operations
      "space g g": "git_panel::ToggleFocus",          // <leader>gg
      "space g c": "git_panel::ToggleFocus",          // <leader>gc (approximate)

      // Buffer management
      "space b d": "pane::CloseActiveItem",           // <leader>bd
      "space b o": "pane::CloseOtherItems",           // <leader>bo

      // Center screen on scroll (matches Neovim <C-d>zz and <C-u>zz)
      "ctrl-d": ["vim::ScrollDown", { "center_cursor": true }],
      "ctrl-u": ["vim::ScrollUp", { "center_cursor": true }],

      // Better j/k movement with count
      "j": "vim::Down",
      "k": "vim::Up",

      // UI toggles — space u prefix (mirrors Neovim <leader>u)
      "space u h": "editor::ToggleInlayHints",
      "space u l": "editor::ToggleRelativeLineNumbers",
      "space u e": "workspace::ToggleLeftDock",
      "space u E": "workspace::ToggleRightDock",
      "space u z": "workspace::ToggleZoom",
      "space u D": "workspace::CloseAllDocks",

      // Go to file with gf
      "g f": "editor::OpenExcerpts"
    }
  },

  // =====================================================
  // NORMAL MODE SPECIFIC BINDINGS
  // =====================================================
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // LSP Navigation (matches Neovim)
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",   // matches Neovim gD
      "g r": "editor::FindAllReferences",     // matches Neovim gr
      "g I": "editor::GoToImplementation",    // matches Neovim gI
      "g y": "editor::GoToTypeDefinition",    // matches Neovim gy
      "g S": "editor::GoToDefinition",        // matches Neovim gS (approximate)

      // Code actions (matches Neovim <leader>ca / <leader>cr)
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",          // <leader>cr; ctrl-r restored to redo

      // Diagnostics navigation
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",
      "] e": "editor::GoToDiagnostic",
      "[ e": "editor::GoToPreviousDiagnostic",

      // Git hunks
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      // Symbol search
      "space s s": "outline::Toggle",         // matches Neovim <leader>ss
      "space s S": "project_symbols::Toggle", // matches Neovim <leader>sS

      // Diagnostics
      "space x d": "diagnostics::Deploy",     // matches Neovim diagnostics

      // AI/Assistant (matches Neovim Claude keybinds)
      "space a c": "agent::ToggleFocus",      // <leader>ac
      "space a f": "agent::ToggleFocus",      // <leader>af
      "space a o": ["task::Spawn", { "task_name": "OpenCode" }], // <leader>ao

      // Git panel
      "ctrl-shift-g": "git_panel::ToggleFocus"
      // Note: ctrl-r intentionally NOT rebound here — restored to vim redo
    }
  },

  // =====================================================
  // VISUAL MODE BINDINGS
  // =====================================================
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      // Comment toggle
      "g c": "editor::ToggleComments",

      // Paste without yanking (approximate to Neovim <leader>p)
      "space p": "editor::Paste",

      // Copy to system clipboard (matches Neovim y in visual)
      "y": "editor::Copy"
    }
  },

  // =====================================================
  // VIM OPERATOR BINDINGS
  // =====================================================
  {
    "context": "Editor && vim_operator == c",
    "bindings": {
      "r": "editor::Rename",
      "c": "vim::CurrentLine",
      "a": "editor::ToggleCodeActions"
    }
  },

  // =====================================================
  // PROJECT PANEL (File Explorer)
  // Single-letter file ops must be context-scoped.
  // Ctrl-combos (ctrl-y, ctrl-shift-y, ctrl-p) are
  // now global — no longer duplicated here.
  // =====================================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "y": "project_panel::Copy",
      "p": "project_panel::Paste",
      "left": "project_panel::CollapseSelectedEntry",
      "right": "project_panel::ExpandSelectedEntry",
      "l": "project_panel::ExpandSelectedEntry",
      "h": "project_panel::CollapseSelectedEntry",
      "shift-h": "project_panel::CollapseAllEntries",
      "escape": "menu::Cancel"
    }
  },

  // =====================================================
  // VIM MULTI-CURSOR (select next/prev match)
  // =====================================================
  {
    "context": "VimControl && !menu",
    "bindings": {
      "g n": "vim::SelectNextMatch",
      "g shift-n": "vim::SelectPreviousMatch",
      "g l": "vim::SelectNext",
      "g shift-l": "vim::SelectPrevious",
      "g >": ["editor::SelectNext", { "replace_newest": true }],
      "g <": ["editor::SelectPrevious", { "replace_newest": true }],
      "g a": "editor::SelectAllMatches"
    }
  },

  // =====================================================
  // VIM MOTION ENHANCEMENTS
  // =====================================================
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      // Syntax node selection
      "alt-o": "editor::SelectLargerSyntaxNode",
      "alt-i": "editor::SelectSmallerSyntaxNode",

      // Flash/Sneak-like navigation
      "s": "vim::PushSneak",
      "S": "vim::PushSneakBackward"
    }
  },

  // =====================================================
  // SUBWORD MOTION
  // =====================================================
  {
    "context": "VimControl && !menu && vim_mode != operator",
    "bindings": {
      "w": "vim::NextSubwordStart",
      "b": "vim::PreviousSubwordStart",
      "e": "vim::NextSubwordEnd",
      "g e": "vim::PreviousSubwordEnd"
    }
  },

  // =====================================================
  // EDITOR FULL MODE (multibuffer excerpts)
  // =====================================================
  {
    "context": "Editor && mode == full",
    "bindings": {
      "shift-enter": ["editor::ExpandExcerpts", { "lines": 5 }]
    }
  },

  // =====================================================
  // HELIX-STYLE JUMP (ss)
  // =====================================================
  {
    "context": "(vim_mode == visual || vim_mode == normal) && !menu",
    "bindings": {
      "s s": "vim::HelixJumpToWord"
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "g w": "vim::HelixJumpToWord"
    }
  },
  {
    "context": "v",
    "bindings": {
      "v i t": "vim::Tag"
    }
  }
]
